# Truth of Auditor — environment variables (produksi)
# Set ini di Railway → service → Variables.

# WAJIB: kunci rahasia acak & panjang (jangan pakai default dev).
SECRET_KEY=ganti-dengan-kunci-acak-panjang-50-karakter

# WAJIB di produksi:
DEBUG=False

# Railway mengisi otomatis (JANGAN diisi manual):
#   RAILWAY_PUBLIC_DOMAIN  -> masuk ALLOWED_HOSTS + CSRF_TRUSTED_ORIGINS
#   DATABASE_URL           -> Postgres (tambahkan Postgres plugin di Railway)
#   PORT                   -> port gunicorn

# Opsional (CSV) bila pakai domain custom:
# ALLOWED_HOSTS=domainku.com,www.domainku.com
# CSRF_TRUSTED_ORIGINS=https://domainku.com

# Opsional: matikan paksa-redirect HTTPS bila perlu (default True saat DEBUG=False)
# SECURE_SSL_REDIRECT=True
